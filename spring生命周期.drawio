                <mxCell id="96" value="DefoultAutoProxy来决定代理类型&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;：&lt;/span&gt;&lt;div&gt;&lt;div&gt;目标类实现了接口 → JdkDynamicAopProxy（基于 InvocationHandler，Proxy.newProxyInstance()）&lt;/div&gt;&lt;div&gt;目标类无接口 或 @EnableAspectJAutoProxy(proxyTargetClass = true) → ObjenesisCglibAopProxy（基于 ASM 生成子类，Objenesis 绕过构造方法）&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="-125" y="-20" width="390" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="101" value="" style="edgeStyle=none;html=1;" edge="1" parent="1" source="98" target="100">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="98" value="代理对象内部通过 TargetSource 持有原始 Bean&lt;div&gt;Advisor[]:&amp;nbsp; 拦截器责任链&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="-105" y="170" width="350" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="100" value="方法调用责任链&lt;div&gt;最终执行TargetSource.getTarget().method()&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="-65" y="295" width="270" height="70" as="geometry"/>
                </mxCell>
